{
  "base_model": "Qwen/Qwen2.5-1.5B-Instruct",
  "train_file": "training/data/sft_train.jsonl",
  "eval_file": "training/data/sft_eval.jsonl",
  "output_dir": "training/artifacts/qwen2.5-1.5b-interview-full-ru-local-v1",
  "num_train_epochs": 2,
  "per_device_train_batch_size": 1,
  "per_device_eval_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.0002,
  "warmup_ratio": 0.03,
  "logging_steps": 5,
  "max_seq_length": 1024,
  "lora_r": 8,
  "lora_alpha": 16,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "up_proj",
    "down_proj",
    "gate_proj"
  ],
  "load_in_4bit": true,
  "bnb_4bit_quant_type": "nf4",
  "bnb_4bit_compute_dtype": "float16",
  "bnb_4bit_use_double_quant": true,
  "device_map": "auto",
  "fp16": true,
  "bf16": false,
  "max_steps": -1,
  "eval_strategy": "steps",
  "eval_steps": 25,
  "save_strategy": "steps",
  "save_steps": 25,
  "save_total_limit": 2,
  "gradient_checkpointing": true,
  "optim": "paged_adamw_8bit",
  "lr_scheduler_type": "cosine",
  "weight_decay": 0.0,
  "max_grad_norm": 0.3
}
