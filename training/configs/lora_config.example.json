{
  "base_model": "Qwen/Qwen2.5-3B-Instruct",
  "train_file": "training/data/sft_train.jsonl",
  "eval_file": "training/data/sft_eval.jsonl",
  "output_dir": "training/artifacts/qwen2.5-3b-interview-v1",
  "num_train_epochs": 2,
  "per_device_train_batch_size": 1,
  "per_device_eval_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.0002,
  "warmup_ratio": 0.03,
  "logging_steps": 5,
  "max_seq_length": 2048,
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "up_proj",
    "down_proj",
    "gate_proj"
  ],
  "fp16": false,
  "bf16": false,
  "max_steps": -1,
  "eval_strategy": "epoch",
  "save_strategy": "epoch",
  "gradient_checkpointing": false
}
