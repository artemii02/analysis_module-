ANALYSIS_API_KEY=demo-api-key
ANALYSIS_LOG_LEVEL=INFO
ANALYSIS_LLM_MODE=hf
ANALYSIS_JOB_STORE_BACKEND=postgres
ANALYSIS_DATABASE_URL=postgresql://analysis:analysis@localhost:5432/analysis_module
ANALYSIS_HF_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
ANALYSIS_HF_ADAPTER_PATH=training/artifacts/qwen2.5-3b-interview-full-ru-qlora-v1
ANALYSIS_HF_DEVICE=cpu
ANALYSIS_HF_LOAD_IN_4BIT=false
ANALYSIS_HF_MAX_NEW_TOKENS=220
ANALYSIS_HF_BATCH_SIZE=3
ANALYSIS_HF_RETRY_MAX_NEW_TOKENS=320
ANALYSIS_HF_REPAIR_MAX_NEW_TOKENS=220
ANALYSIS_WARMUP_LLM_ON_START=false
ANALYSIS_REQUEST_TIMEOUT_SECONDS=300
ANALYSIS_KNOWLEDGE_LIMIT=1
ANALYSIS_HARD_TIMEOUT_SECONDS=30
ANALYSIS_MAX_ANSWER_LENGTH=4000
ANALYSIS_MAX_SESSION_ITEMS=20
